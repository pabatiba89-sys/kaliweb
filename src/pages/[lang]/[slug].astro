---
import PublicLayout from '../../layouts/PublicLayout.astro';
import { getPage, pagePath, pagesByLocale, supportedLocales } from '../../site/content.js';
import { translateText } from '../../site/localization.js';
import { brandName } from '../../site/localization.js';

export function getStaticPaths() {
  return supportedLocales.flatMap((lang) => pagesByLocale[lang].map((page) => ({ params: { lang, slug: page.slug }, props: { lang, page } })));
}

const { lang, page } = Astro.props;
const t = (value) => translateText(value, lang);
const allPages = pagesByLocale[lang] || [];
const findPage = (slug) => allPages.find((item) => item.slug === slug);
const isHelpIndex = page.contentType === 'helpIndex';
const isGuide = page.contentType === 'guide';
const relatedPages = (page.related || []).map(findPage).filter(Boolean);
const pageSchema = {
  '@type': 'WebPage',
  name: page.title,
  description: page.description,
  url: new URL(pagePath(lang, page.slug), Astro.site),
  isPartOf: { '@id': `${Astro.site}#website` },
  about: { '@id': `${Astro.site}#organization` },
  inLanguage: lang,
};
const howToSchema = isGuide ? {
  '@type': 'HowTo',
  name: page.title,
  description: page.description,
  step: page.steps.map((step) => ({ '@type': 'HowToStep', name: step.title, text: step.body })),
  inLanguage: lang,
} : null;
const faqSchema = {
  '@type': 'FAQPage',
  mainEntity: page.faq.map(([question, answer]) => ({ '@type': 'Question', name: question, acceptedAnswer: { '@type': 'Answer', text: answer } })),
};
---
<PublicLayout locale={lang} slug={page.slug} title={`${page.title} | ${brandName(lang)}`} description={page.description} eyebrow={page.eyebrow} schema={[pageSchema, howToSchema, faqSchema].filter(Boolean)}>
  <section class:list={['page-hero', { 'help-hero': isHelpIndex || isGuide }]}>
    <div><p class="eyebrow">{page.eyebrow}</p><h1>{page.headline}</h1><p class="hero-lead">{page.lead}</p>{!isHelpIndex && !isGuide && <div class="hero-actions"><a class="primary-cta" href="/app/">{t('Open the workspace')} <span>↗</span></a><a class="text-cta" href={pagePath(lang, 'contact')}>{t('Talk to the team')} <span>→</span></a></div>}</div>
    <aside><p>{isGuide ? t('IN THIS GUIDE') : t('WHAT YOU CAN DO')}</p><ul>{page.bullets.map((bullet) => <li><span>✓</span>{bullet}</li>)}</ul></aside>
  </section>

  {isHelpIndex && (
    <>
      <section class="help-groups">
        <div class="section-heading"><p class="eyebrow">{t('START HERE')}</p><h2>{t('Guides grouped by the production path')}</h2></div>
        <div class="help-group-grid">
          {page.groups.map((group) => (
            <article class="help-group-card">
              <h3>{group.title}</h3>
              <p>{group.description}</p>
              <div>
                {group.links.map((slug) => {
                  const item = findPage(slug);
                  return item && <a href={pagePath(lang, item.slug)}><span>{item.eyebrow}</span><strong>{item.headline}</strong></a>;
                })}
              </div>
            </article>
          ))}
        </div>
      </section>
      <section class="help-roadmap">
        <div class="section-heading"><p class="eyebrow">{t('BATCH PLAN')}</p><h2>{t('Build the help center in useful layers')}</h2></div>
        <ol>{page.roadmap.map(([label, body]) => <li><span>{label}</span><p>{body}</p></li>)}</ol>
      </section>
    </>
  )}

  {isGuide && (
    <>
      <section class="guide-prep">
        <article>
          <p class="eyebrow">{t('USE THIS WHEN')}</p>
          <ul>{page.useWhen.map((item) => <li>{item}</li>)}</ul>
        </article>
        <article>
          <p class="eyebrow">{t('BEFORE YOU START')}</p>
          <ul>{page.beforeYouStart.map((item) => <li>{item}</li>)}</ul>
        </article>
      </section>
      <section class="guide-visual-section">
        <div class="guide-visual-card">
          <div>
            <p class="eyebrow">{page.visual.label}</p>
            <ol>{page.visual.stages.map((stage, index) => <li><span>{String(index + 1).padStart(2, '0')}</span><strong>{stage}</strong></li>)}</ol>
          </div>
          <img src={page.visual.image} alt={page.visual.label} loading="lazy" />
        </div>
      </section>
      <section class="guide-steps">
        <div class="section-heading"><p class="eyebrow">{t('STEP BY STEP')}</p><h2>{t('Follow the workflow in order')}</h2></div>
        <div class="guide-step-list">
          {page.steps.map((step, index) => <article><span>{String(index + 1).padStart(2, '0')}</span><div><h3>{step.title}</h3><p>{step.body}</p>{step.details?.length > 0 && <ul>{step.details.map((item) => <li>{item}</li>)}</ul>}</div></article>)}
        </div>
      </section>
      <section class="guide-checks">
        <article>
          <p class="eyebrow">{t('CHECK BEFORE YOU SUBMIT')}</p>
          <ul>{page.checkpoints.map((item) => <li>{item}</li>)}</ul>
        </article>
        <article>
          <p class="eyebrow">{t('COMMON MISTAKES')}</p>
          <ul>{page.mistakes.map((item) => <li>{item}</li>)}</ul>
        </article>
        <article>
          <p class="eyebrow">{t('IF SOMETHING GOES WRONG')}</p>
          <ul>{page.recovery.map((item) => <li>{item}</li>)}</ul>
        </article>
      </section>
      {relatedPages.length > 0 && (
        <section class="related-guides">
          <div class="section-heading"><p class="eyebrow">{t('RELATED GUIDES')}</p><h2>{t('Continue with the next useful article')}</h2></div>
          <div>{relatedPages.map((item) => <a href={pagePath(lang, item.slug)}><span>{item.eyebrow}</span><strong>{item.headline}</strong><p>{item.description}</p></a>)}</div>
        </section>
      )}
    </>
  )}

  {!isHelpIndex && !isGuide && (
    <section class="detail-section">
      <div class="section-heading"><p class="eyebrow">{t('HOW IT FITS TOGETHER')}</p><h2>{t('A clear path from setup to repeatable output')}</h2></div>
      <div class="detail-grid">{page.sections.map(([heading, body], index) => <article><span>0{index + 1}</span><h3>{heading}</h3><p>{body}</p></article>)}</div>
    </section>
  )}
  <section class="faq-section">
    <div class="section-heading"><p class="eyebrow">{t('COMMON QUESTIONS')}</p><h2>{t('Answers before you start')}</h2></div>
    <div class="faq-list">{page.faq.map(([question, answer]) => <details><summary>{question}<span>+</span></summary><p>{answer}</p></details>)}</div>
  </section>
  {!isHelpIndex && !isGuide && <section class="closing-cta"><p class="eyebrow">{t('KALI WORKSPACE')}</p><h2>{t('Bring your next idea to life.')}</h2><a class="primary-cta dark" href="/app/">{t('Create with Kali')} <span>↗</span></a></section>}
  {(isHelpIndex || isGuide) && <section class="help-footer-actions"><a href={pagePath(lang, 'help')}>{t('Back to help center')}</a><a href="/app/">{t('Open the workspace')} <span>↗</span></a></section>}
</PublicLayout>
