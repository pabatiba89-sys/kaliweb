---
import { localeMeta, pagePath, siteName, supportedLocales } from '../site/content.js';
import { translateText } from '../site/localization.js';
import '../site/public.css';

const {
  locale = 'en',
  title,
  description,
  slug = '',
  eyebrow = '',
  schema = [],
} = Astro.props;
const copy = localeMeta[locale];
const t = (value) => translateText(value, locale);
const canonicalPath = pagePath(locale, slug);
const canonical = new URL(canonicalPath, Astro.site);
const alternates = supportedLocales.map((code) => ({
  code: localeMeta[code].hreflang,
  href: new URL(pagePath(code, slug), Astro.site),
}));
const graph = Array.isArray(schema) ? schema : [schema];
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${Astro.site}#organization`,
      name: siteName,
      legalName: '上海喀理科技有限公司',
      url: Astro.site,
      email: 'feedback@xyaip.fun',
    },
    {
      '@type': 'WebSite',
      '@id': `${Astro.site}#website`,
      name: siteName,
      url: Astro.site,
      publisher: { '@id': `${Astro.site}#organization` },
      inLanguage: copy.appLocale,
    },
    ...graph,
  ],
};
---
<!doctype html>
<html lang={copy.appLocale} dir={copy.dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={canonical} />
    {alternates.map((item) => <link rel="alternate" hreflang={item.code} href={item.href} />)}
    <link rel="alternate" hreflang="x-default" href={new URL('/en/', Astro.site)} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL('/og.png', Astro.site)} />
    <meta property="og:image:width" content="1734" />
    <meta property="og:image:height" content="907" />
    <meta property="og:image:alt" content="Kali AI content production workflow" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/og.png', Astro.site)} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a class="skip-link" href="#main">{t('Skip to content')}</a>
    <header class="site-header">
      <a class="brand" href={pagePath(locale)} aria-label={`${siteName} home`}>
        <span class="brand-mark" aria-hidden="true">K</span>
        <span><strong>Kali AI</strong><small>{t('Content production workspace')}</small></span>
      </a>
      <nav aria-label={t('Primary navigation')}>
        <a href={pagePath(locale)}>{copy.home}</a>
        <a href={pagePath(locale, 'ai-video-generator')}>{copy.product}</a>
        <a href={pagePath(locale, 'pricing')}>{copy.pricing}</a>
        <a href={pagePath(locale, 'about')}>{copy.about}</a>
        <a href={pagePath(locale, 'contact')}>{copy.contact}</a>
      </nav>
      <div class="header-actions">
        <details class="language-switcher">
          <summary aria-label={copy.label}>{copy.label}<span aria-hidden="true">⌄</span></summary>
          <div class="language-menu">
            {supportedLocales.map((code) => <a class:list={{ active: code === locale }} href={pagePath(code, slug)} lang={localeMeta[code].appLocale} dir={localeMeta[code].dir}>{localeMeta[code].label}</a>)}
          </div>
        </details>
        <a class="header-cta" href="/app/">{copy.workspace}<span aria-hidden="true">↗</span></a>
      </div>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="public-footer">
      <div class="footer-brand">
        <span class="brand-mark" aria-hidden="true">K</span>
        <div><strong>Kali AI</strong><p>{t('From trend discovery to publish-ready media.')}</p></div>
      </div>
      <div class="footer-links">
        <div><strong>{t('Product')}</strong><a href={pagePath(locale, 'ai-video-generator')}>{t('AI video')}</a><a href={pagePath(locale, 'digital-human')}>{t('Digital humans')}</a><a href={pagePath(locale, 'voice-cloning')}>{t('Voice cloning')}</a><a href={pagePath(locale, 'ai-music-generator')}>{t('AI music')}</a></div>
        <div><strong>{t('Company')}</strong><a href={pagePath(locale, 'about')}>{copy.about}</a><a href={pagePath(locale, 'contact')}>{copy.contact}</a><a href="mailto:feedback@xyaip.fun">{t('Product feedback')}</a></div>
        <div><strong>{t('Workspace')}</strong><a href="/app/">{t('Open Kali AI')}</a><a href="mailto:privacy@xyaip.fun">{t('Privacy requests')}</a></div>
      </div>
      <div class="footer-bottom"><span>© 2026 上海喀理科技有限公司</span><span>{eyebrow || t('Kali AI · Yixiu System')}</span></div>
    </footer>
  </body>
</html>
